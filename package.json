{
  "name": "lecrev",
  "private": true,
  "license": "MIT",
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "@types/bun": "1.3.13",
      "effect": "4.0.0-beta.65"
    }
  },
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "prepare": "lefthook install && effect-language-service patch",
    "check": "oxlint -c ./.oxlintrc.json --fix && oxfmt --write",
    "start": "turbo run start",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "infra:logs": "docker compose logs -f",
    "dev:with-infra": "docker compose up -d && turbo run dev"
  },
  "devDependencies": {
    "@effect/language-service": "^0.85.1",
    "@lecrev/config": "workspace:*",
    "@types/bun": "catalog:",
    "lefthook": "^2.1.6",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.63.0",
    "oxlint-tsgolint": "^0.22.1",
    "turbo": "^2.9.9",
    "typescript": "^6.0.3"
  },
  "engines": {
    "bun": ">=1.3.13"
  },
  "packageManager": "bun@1.3.13"
}
