{
  "name": "lecrev",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "prepare": "lefthook install && effect-language-service patch",
    "check": "oxlint -c ./.oxlintrc.json --fix && oxfmt --write",
    "start": "turbo run start",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "infra:logs": "docker compose logs -f",
    "dev:with-infra": "docker compose up -d && turbo run dev"
  },
  "devDependencies": {
    "@effect/language-service": "^0.86.1",
    "@lecrev/config": "workspace:*",
    "@types/node": "catalog:",
    "lefthook": "^2.1.6",
    "oxfmt": "^0.49.0",
    "oxlint": "^1.64.0",
    "oxlint-tsgolint": "^0.22.1",
    "turbo": "^2.9.12",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@11.1.2"
}
